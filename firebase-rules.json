{
  "rules": {
    "messages": {
      ".read": true,
      ".indexOn": ["ts"],
      "$msgId": {
        ".write": "!data.exists() && newData.exists()",
        ".validate": "newData.hasChildren(['nick','text','ts','ip'])
          && newData.child('text').isString()
          && newData.child('text').val().length >= 1
          && newData.child('text').val().length <= 20
          && newData.child('nick').isString()
          && newData.child('nick').val().length <= 30
          && newData.child('ts').isNumber()
          && newData.child('ip').isString()
          && (!newData.hasChild('admin') || newData.child('admin').isBoolean())"
      }
    },
    "bans": {
      ".read": true,
      "$ipHash": {
        ".write": "auth != null && auth.uid === 'pVNCtNqzoGgmmUSnshkBIICaz452'",
        ".validate": "newData.hasChildren(['banned_at','banned_by'])"
      }
    },
    "votes": {
      ".read": true,
      "$date": {
        "$ipHash": {
          ".write": "auth != null && !data.exists() && newData.exists()",
          ".validate": "newData.hasChildren(['vote','ts'])
            && (newData.child('vote').val() === 'up' || newData.child('vote').val() === 'down')
            && newData.child('ts').isNumber()
            && (!newData.hasChild('nick') || newData.child('nick').isString())"
        }
      }
    },
    "predictions": {
      ".read": true,
      "$date": {
        "$ipHash": {
          ".write": "!data.exists() && newData.exists()",
          ".validate": "newData.child('ts').isNumber()"
        }
      }
    },
    "presence": {
      ".read": true,
      "$hash": {
        ".write": true
      }
    },
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
